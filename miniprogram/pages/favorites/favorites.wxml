<view class="page">
  <view class="page-header">
    <view class="page-title">我的收藏</view>
    <button
      class="manage-button"
      wx:if="{{verified && !authLoading && !isLoading && favoriteNotices.length}}"
      bindtap="toggleManageMode"
    >
      {{manageMode ? '完成' : '管理'}}
    </button>
  </view>

  <view class="state-card" wx:if="{{authLoading}}">
    <view class="state-title">身份检查中...</view>
  </view>

  <view class="state-card" wx:elif="{{!verified}}">
    <view class="state-title">请先完成班级身份验证</view>
    <view class="state-desc">验证后即可查看已收藏的班级事项</view>
    <button class="verify-button" bindtap="goMemberVerify">去验证</button>
  </view>

  <view class="state-card" wx:elif="{{isLoading}}">
    <view class="state-title">加载中...</view>
    <view class="state-desc">正在同步收藏事项</view>
  </view>

  <view class="state-card error" wx:elif="{{loadError}}">
    <view class="state-title">加载失败</view>
    <view class="state-desc">请稍后重试</view>
  </view>

  <view class="card-list" wx:else>
    <view
      class="notice-card {{item.isExpired ? 'expired' : ''}} {{item.selected ? 'selected' : ''}} {{manageMode ? 'manage' : ''}}"
      wx:for="{{favoriteNotices}}"
      wx:key="_id"
      data-id="{{item._id}}"
      data-favorite-id="{{item.favoriteId}}"
      bindtap="goDetail"
    >
      <view class="select-box {{item.selected ? 'checked' : ''}}" wx:if="{{manageMode}}">
        <text wx:if="{{item.selected}}">✓</text>
      </view>
      <view class="card-main">
        <view class="tag-row">
          <view class="tag">{{item.category}}</view>
          <view class="status-tag {{item.isExpired ? 'expired' : 'active'}}">{{item.statusText}}</view>
        </view>
        <view class="card-title">{{item.title}}</view>
        <view class="time-row">
          <text class="time-label">{{item.timeLabel || '时间'}}</text>
          <text class="time-value">{{item.timeText || item.deadline || '未填写'}}</text>
        </view>
        <view class="meta-row">
          <text class="meta-label">发布人</text>
          <text class="meta-value">{{item.publisherNameText || '未知'}}</text>
        </view>
      </view>
    </view>

    <view class="state-card empty" wx:if="{{favoriteNotices.length == 0}}">
      <view class="state-title">暂无收藏事项</view>
      <view class="state-desc">在事项详情页点击收藏后会显示在这里</view>
    </view>
  </view>

  <view class="batch-bar" wx:if="{{manageMode}}">
    <view class="batch-count">已选 {{selectedFavoriteIds.length}} 项</view>
    <button
      class="batch-cancel-button"
      loading="{{batchLoading}}"
      disabled="{{batchLoading}}"
      bindtap="batchCancelFavorite"
    >
      取消收藏
    </button>
  </view>
</view>
