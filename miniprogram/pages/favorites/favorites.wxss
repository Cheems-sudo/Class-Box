/* 页面样式：定义 favorites 页面的布局、视觉状态与响应式细节。 */
page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.page-header {
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.page-title {
  color: #0f172a;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.25;
}

.manage-button {
  flex: 0 0 auto;
  margin: 0;
  min-width: 108rpx;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #dbe7f3;
  color: #2563eb;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 58rpx;
  box-shadow: none;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.notice-card {
  padding: 26rpx 28rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  border-left: 6rpx solid #dbeafe;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
}

.notice-card.manage {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.notice-card.selected {
  border-color: #bfdbfe;
  border-left-color: #2563eb;
  background: #f8fbff;
}

.card-main {
  flex: 1;
  min-width: 0;
}

.select-box {
  flex: 0 0 auto;
  width: 38rpx;
  height: 38rpx;
  margin-top: 4rpx;
  border-radius: 999rpx;
  border: 2rpx solid #cbd5e1;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
}

.select-box.checked {
  background: #2563eb;
  border-color: #2563eb;
}

.notice-card.expired {
  background: #fbfcfe;
  border-color: #eef2f7;
  box-shadow: none;
  opacity: 0.78;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag,
.status-tag {
  min-height: 38rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tag {
  background: #eff6ff;
  color: #1d4ed8;
}

.status-tag.active {
  background: #e7f8ef;
  color: #047857;
}

.status-tag.expired {
  background: #eef2f6;
  color: #64748b;
}

.card-title {
  margin-top: 18rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.time-row {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #e8eef6;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.time-label,
.meta-label {
  color: #94a3b8;
  font-size: 24rpx;
}

.time-value {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.meta-row {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.meta-value {
  min-width: 0;
  color: #334155;
  font-size: 27rpx;
  line-height: 1.4;
  text-align: right;
  word-break: break-all;
}

.state-card {
  padding: 72rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx dashed #cbd5e1;
  text-align: center;
}

.state-card.error {
  border-color: #fecaca;
  background: #fff7f7;
}

.state-title {
  color: #475569;
  font-size: 30rpx;
  font-weight: 600;
}

.state-desc {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 25rpx;
}

.verify-button {
  margin: 26rpx auto 0;
  width: 180rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.16);
}

.batch-bar {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  z-index: 20;
  min-height: 92rpx;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.12);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.batch-count {
  color: #475569;
  font-size: 26rpx;
  font-weight: 600;
}

.batch-cancel-button {
  flex: 0 0 auto;
  margin: 0;
  min-width: 180rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #fef2f2;
  color: #b91c1c;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 64rpx;
  box-shadow: none;
}
