<view class="page">
  <view class="hero">
    <view class="hero-main">
      <view class="title">事项概览</view>
    </view>
    <view class="hero-stats">
      <view class="stat-item">
        <view class="stat-value">{{runningNoticeCount}}</view>
        <view class="stat-label">进行中</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value important-stat">{{importantNoticeCount}}</view>
        <view class="stat-label">重要</view>
      </view>
    </view>
  </view>

  <view class="state-card verify-card" wx:if="{{authLoading}}">
    <view class="state-title">身份检查中...</view>
    <view class="state-desc">正在确认班级成员身份</view>
  </view>

  <view class="state-card verify-card" wx:elif="{{!verified}}">
    <view class="state-title">请先完成班级身份验证</view>
    <view class="state-desc">验证后即可查看班级事项列表</view>
    <button class="verify-button" bindtap="goMemberVerify" hover-class="button-pressed" hover-stay-time="80">去验证</button>
  </view>

  <block wx:else>
  <view class="important-section" wx:if="{{importantNoticeList.length}}">
    <view class="section-head">
      <view>
        <view class="section-eyebrow">重点提醒</view>
        <view class="important-title">重要事项</view>
      </view>
      <view class="section-count">{{importantNoticeList.length}} 项</view>
    </view>
    <view
      class="important-card category-{{item.categoryClass}}"
      wx:for="{{importantNoticeList}}"
      wx:key="_id"
      data-notice-id="{{item._id}}"
      bindtap="goDetail"
      hover-class="card-pressed"
      hover-stay-time="80"
    >
      <view class="important-main">
        <view class="tag">{{item.displayCategory || item.category}}</view>
        <view class="pin-tag" wx:if="{{item.isPinned}}">置顶</view>
        <view class="important-card-title">{{item.title}}</view>
      </view>
      <view class="important-time">
        <text class="time-label">{{item.timeLabel || '时间'}}</text>
        <text class="time-value">{{item.timeText || item.deadline || '未填写'}}</text>
      </view>
      <view class="important-meta">
        <view class="important-meta-item" wx:if="{{item.courseText}}">
          <text class="meta-label">{{item.courseLabel}}</text>
          <text class="meta-value">{{item.courseText}}</text>
        </view>
        <view class="important-meta-item" wx:if="{{item.locationText}}">
          <text class="meta-label">{{item.locationLabel}}</text>
          <text class="meta-value">{{item.locationText}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="search-box">
    <text class="search-icon">⌕</text>
    <input
      class="search-input"
      value="{{searchKeyword}}"
      placeholder="搜索课程、活动或通知"
      placeholder-class="search-placeholder"
      confirm-type="search"
      bindinput="onSearchInput"
    />
  </view>

  <view class="filter-block">
    <scroll-view class="category-scroll" scroll-x enable-flex>
      <view class="category-list">
        <view
          class="category {{activeCategory == item.value ? 'active' : ''}}"
          wx:for="{{categoryTabs}}"
          wx:key="value"
          data-category="{{item.value}}"
          bindtap="changeCategory"
          hover-class="filter-pressed"
          hover-stay-time="80"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="filter-block status-block">
    <view class="status-filter">
      <view
        class="status-option {{activeStatus == item ? 'active' : ''}}"
        wx:for="{{statusFilters}}"
        wx:key="*this"
        data-status="{{item}}"
        bindtap="changeStatus"
        hover-class="filter-pressed"
        hover-stay-time="80"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view class="card-list">
    <view class="state-card" wx:if="{{isLoading}}">
      <view class="state-title">加载中...</view>
      <view class="state-desc">正在同步班级事项</view>
    </view>

    <view class="state-card error" wx:elif="{{loadError}}">
      <view class="state-title">加载失败，请下拉刷新重试</view>
      <view class="state-desc">请检查网络或稍后再试</view>
    </view>

    <block wx:else>
      <view
        class="notice-card category-{{item.categoryClass}} {{item.isExpired ? 'expired' : ''}}"
        wx:for="{{filteredNoticeList}}"
        wx:key="_id"
        data-index="{{index}}"
        bindtap="goDetail"
        hover-class="card-pressed"
        hover-stay-time="80"
      >
        <view class="card-top">
          <view class="tag-row">
            <view class="tag">{{item.displayCategory || item.category}}</view>
            <view class="pin-tag" wx:if="{{item.isPinned}}">置顶</view>
            <view class="important" wx:if="{{item.important}}">重要</view>
            <view class="status-tag expired" wx:if="{{item.isExpired}}">已过期</view>
          </view>
        </view>
        <view class="card-title">{{item.title}}</view>
        <view class="time-row">
          <text class="time-label">{{item.timeLabel || '时间'}}</text>
          <text class="time-value">{{item.timeText || item.deadline || '未填写'}}</text>
        </view>
        <view class="info-grid">
          <view class="info-item" wx:if="{{item.courseText}}">
            <text class="meta-label">{{item.courseLabel}}</text>
            <text class="meta-value">{{item.courseText}}</text>
          </view>
          <view class="info-item" wx:if="{{item.locationText}}">
            <text class="meta-label">{{item.locationLabel}}</text>
            <text class="meta-value">{{item.locationText}}</text>
          </view>
          <view class="info-item">
            <text class="meta-label">发布人</text>
            <text class="meta-value">{{item.publisherNameText || '未知'}}</text>
          </view>
        </view>
      </view>
      <view class="state-card empty" wx:if="{{filteredNoticeList.length == 0}}">
        <view class="empty-mark">{{noticeList.length == 0 ? '待' : '空'}}</view>
        <block wx:if="{{noticeList.length == 0}}">
          <view class="state-title">暂无班级事项</view>
          <view class="state-desc">发布后的事项会显示在这里</view>
        </block>
        <block wx:elif="{{searchKeyword}}">
          <view class="state-title">没有找到匹配事项</view>
          <view class="state-desc">可以换个关键词，或切换分类和状态筛选</view>
        </block>
        <block wx:else>
          <view class="state-title">暂无相关事项</view>
          <view class="state-desc">可以切换分类或状态查看其他事项</view>
        </block>
      </view>
    </block>
  </view>
</block>
</view>
