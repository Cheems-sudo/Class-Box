page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.header {
  margin-bottom: 24rpx;
  padding: 26rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
}

.title {
  color: #0f172a;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.45;
}

.search-box {
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  display: flex;
  align-items: center;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.search-icon {
  margin-right: 12rpx;
  color: #94a3b8;
  font-size: 30rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  height: 76rpx;
  color: #0f172a;
  font-size: 27rpx;
  line-height: 76rpx;
}

.search-placeholder {
  color: #94a3b8;
  font-size: 27rpx;
}

.filter-block {
  margin-top: 22rpx;
}

.filter-label {
  margin-bottom: 12rpx;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
}

.category-scroll {
  margin: 0 -28rpx;
  width: 750rpx;
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 14rpx;
  padding: 0 28rpx;
}

.category {
  flex: 0 0 auto;
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  color: #475569;
  font-size: 26rpx;
  line-height: 56rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.035);
}

.category.active {
  background: #2563eb;
  border-color: #2563eb;
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 7rpx 16rpx rgba(37, 99, 235, 0.16);
}

.status-block {
  margin-top: 20rpx;
}

.status-filter {
  margin: 0 0 26rpx;
  padding: 8rpx;
  border-radius: 14rpx;
  background: #e9eef6;
  display: flex;
  gap: 8rpx;
}

.status-option {
  flex: 1;
  height: 60rpx;
  border-radius: 10rpx;
  color: #475569;
  font-size: 26rpx;
  line-height: 60rpx;
  text-align: center;
}

.status-option.active {
  background: #ffffff;
  color: #1d4ed8;
  font-weight: 600;
  box-shadow: 0 5rpx 14rpx rgba(15, 23, 42, 0.07);
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.notice-card {
  position: relative;
  overflow: hidden;
  padding: 26rpx 28rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
}

.notice-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: #94a3b8;
}

.notice-card.category-exam::before {
  background: #ef4444;
}

.notice-card.category-homework::before {
  background: #2563eb;
}

.notice-card.category-activity::before {
  background: #8b5cf6;
}

.notice-card.category-notice::before {
  background: #10b981;
}

.notice-card.category-other::before {
  background: #94a3b8;
}

.notice-card.expired {
  background: #fbfcfe;
  border-color: #eef2f7;
  box-shadow: none;
  opacity: 0.78;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.tag-row {
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag,
.pin-tag,
.important,
.status-tag {
  min-height: 38rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tag {
  background: #f1f5f9;
  color: #334155;
}

.pin-tag {
  background: #f8fafc;
  color: #64748b;
  font-weight: 600;
}

.important {
  background: #fef2f2;
  color: #b91c1c;
  font-weight: 700;
}

.status-tag.active {
  background: #e7f8ef;
  color: #047857;
}

.status-tag.expired {
  background: #eef2f6;
  color: #64748b;
}

.card-title {
  margin-top: 18rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.notice-card.expired .card-title,
.notice-card.expired .time-value,
.notice-card.expired .meta-value {
  color: #64748b;
}

.time-row {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #e8eef6;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.time-label {
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
}

.time-value {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.info-grid {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.info-item {
  min-width: 0;
  width: calc((100% - 16rpx) / 2);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.meta-label {
  color: #94a3b8;
  font-size: 24rpx;
}

.meta-value {
  color: #334155;
  font-size: 27rpx;
  line-height: 1.4;
  word-break: break-all;
}

.state-card {
  padding: 72rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx dashed #cbd5e1;
  text-align: center;
}

.state-card.error {
  border-color: #fecaca;
  background: #fff7f7;
}

.state-title {
  color: #475569;
  font-size: 30rpx;
  font-weight: 600;
}

.state-desc {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 25rpx;
}

.state-card.error .state-title {
  color: #b91c1c;
}

.verify-card {
  margin-top: 22rpx;
}

.verify-button {
  margin: 26rpx auto 0;
  width: 180rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.16);
}
