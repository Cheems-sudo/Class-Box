/* 页面样式：定义 index 页面的布局、视觉状态与响应式细节。 */
page {
  background: #f5f7fb;
}

.page {
  min-height: 100vh;
  padding: 24rpx 28rpx 52rpx;
}

.title {
  color: #0f172a;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.search-box {
  height: 78rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e2eaf4;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 18rpx rgba(30, 41, 59, 0.04);
}

.search-icon {
  margin-right: 12rpx;
  color: #94a3b8;
  font-size: 30rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  height: 78rpx;
  color: #0f172a;
  font-size: 27rpx;
  line-height: 78rpx;
}

.search-placeholder {
  color: #94a3b8;
  font-size: 27rpx;
}

.important-section {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e6edf5;
  box-shadow: 0 10rpx 24rpx rgba(30, 41, 59, 0.045);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.important-title {
  color: #0f172a;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.3;
}

.section-count {
  flex: 0 0 auto;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.3;
}

.important-card {
  position: relative;
  margin-top: 18rpx;
  padding: 22rpx 22rpx 22rpx 26rpx;
  border-radius: 14rpx;
  background: #fbfdff;
  border: 1rpx solid #e7edf5;
  overflow: hidden;
  transition: transform 0.12s ease, box-shadow 0.12s ease, background-color 0.12s ease;
}

.important-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: #94a3b8;
}

.important-card.category-exam::before {
  background: #ef4444;
}

.important-card.category-homework::before {
  background: #2563eb;
}

.important-card.category-activity::before {
  background: #8b5cf6;
}

.important-card.category-notice::before {
  background: #10b981;
}

.important-card.category-other::before {
  background: #94a3b8;
}

.important-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.important-card-title {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.important-time {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.important-meta {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.important-meta-item {
  min-width: 0;
  width: calc((100% - 14rpx) / 2);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.filter-block {
  margin-top: 20rpx;
}

.category-scroll {
  margin: 0 -28rpx;
  width: 750rpx;
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 12rpx;
  padding: 0 28rpx;
}

.category {
  flex: 0 0 auto;
  min-height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #e2eaf4;
  color: #475569;
  font-size: 26rpx;
  line-height: 58rpx;
  text-align: center;
  box-shadow: 0 5rpx 12rpx rgba(30, 41, 59, 0.035);
  transition: transform 0.12s ease, background-color 0.12s ease, border-color 0.12s ease;
}

.category.active {
  background: #2563eb;
  border-color: #2563eb;
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 7rpx 16rpx rgba(37, 99, 235, 0.16);
}

.status-block {
  margin-top: 16rpx;
}

.status-filter {
  margin: 0 0 22rpx;
  padding: 6rpx;
  border-radius: 12rpx;
  background: #eef3f8;
  border: 1rpx solid #e2eaf4;
  display: flex;
  gap: 6rpx;
}

.status-option {
  flex: 1;
  height: 50rpx;
  border-radius: 9rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 50rpx;
  text-align: center;
  transition: transform 0.12s ease, background-color 0.12s ease, color 0.12s ease;
}

.status-option.active {
  background: #ffffff;
  color: #2563eb;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(30, 41, 59, 0.06);
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-card {
  position: relative;
  overflow: hidden;
  padding: 24rpx 28rpx 26rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e6edf5;
  box-shadow: 0 10rpx 24rpx rgba(30, 41, 59, 0.05);
  transition: transform 0.12s ease, box-shadow 0.12s ease, background-color 0.12s ease;
}

.notice-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: #94a3b8;
}

.notice-card.category-exam::before {
  background: #ef4444;
}

.notice-card.category-homework::before {
  background: #2563eb;
}

.notice-card.category-activity::before {
  background: #8b5cf6;
}

.notice-card.category-notice::before {
  background: #10b981;
}

.notice-card.category-other::before {
  background: #94a3b8;
}

.notice-card.expired {
  background: #fbfcfe;
  border-color: #eef2f7;
  box-shadow: none;
  opacity: 0.86;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.tag-row {
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag,
.pin-tag,
.important,
.status-tag {
  min-height: 38rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tag {
  background: #f1f5f9;
  color: #334155;
}

.category-exam .tag {
  background: #fff1f2;
  color: #be123c;
}

.category-homework .tag {
  background: #eff6ff;
  color: #1d4ed8;
}

.category-activity .tag {
  background: #f5f3ff;
  color: #6d28d9;
}

.category-notice .tag {
  background: #ecfdf5;
  color: #047857;
}

.category-other .tag {
  background: #f1f5f9;
  color: #475569;
}

.pin-tag {
  background: #fff7ed;
  color: #c2410c;
  font-weight: 600;
}

.important {
  background: #fef2f2;
  color: #b91c1c;
  font-weight: 700;
}

.status-tag.active {
  background: #e7f8ef;
  color: #047857;
}

.status-tag.expired {
  background: #eef2f6;
  color: #64748b;
}

.card-title {
  margin-top: 16rpx;
  color: #0f172a;
  font-size: 33rpx;
  font-weight: 700;
  line-height: 1.36;
}

.notice-card.expired .card-title,
.notice-card.expired .time-value,
.notice-card.expired .meta-value {
  color: #64748b;
}

.time-row {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #e7edf5;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.time-label {
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
}

.time-value {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.info-grid {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.info-item {
  min-width: 0;
  width: calc((100% - 14rpx) / 2);
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.meta-label {
  color: #94a3b8;
  font-size: 23rpx;
}

.meta-value {
  color: #334155;
  font-size: 26rpx;
  line-height: 1.4;
  word-break: break-all;
}

.state-card {
  padding: 68rpx 30rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx dashed #cbd5e1;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(30, 41, 59, 0.035);
}

.state-card.error {
  border-color: #fecaca;
  background: #fff7f7;
}

.state-title {
  color: #475569;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
}

.state-desc {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 25rpx;
  line-height: 1.45;
}

.state-card.error .state-title {
  color: #b91c1c;
}

.verify-card {
  margin-top: 22rpx;
}

.verify-button {
  margin: 26rpx auto 0;
  width: 180rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.16);
}

.empty {
  padding-top: 58rpx;
  padding-bottom: 60rpx;
}

.empty-mark {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 20rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
}

.card-pressed {
  transform: scale(0.985);
  background: #f8fbff;
  box-shadow: 0 5rpx 14rpx rgba(30, 41, 59, 0.04);
}

.filter-pressed {
  transform: scale(0.97);
  opacity: 0.86;
}

.button-pressed {
  transform: scale(0.96);
  opacity: 0.9;
}

/* TDesign-inspired visual refresh */
page {
  background: #f6f8fb;
}

.page {
  padding: 24rpx 28rpx 54rpx;
}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 206rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e7ecf3;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 26rpx;
}

.hero::before {
  content: "";
  position: absolute;
  right: -64rpx;
  top: -74rpx;
  width: 230rpx;
  height: 230rpx;
  border-radius: 999rpx;
  background: rgba(0, 82, 217, 0.09);
}

.hero::after {
  content: "";
  position: absolute;
  right: 98rpx;
  bottom: 26rpx;
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: rgba(0, 168, 112, 0.12);
  transform: rotate(18deg);
}

.hero-main,
.hero-stats {
  position: relative;
  z-index: 1;
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.hero .title {
  margin-top: 0;
}

.title {
  margin-top: 18rpx;
  color: #111827;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.15;
}

.hero-stats {
  flex: 0 0 232rpx;
  min-height: 138rpx;
  padding: 20rpx 18rpx;
  border-radius: 20rpx;
  background: #f7f9fc;
  border: 1rpx solid #e7ecf3;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.stat-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.stat-value {
  color: #111827;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.15;
}

.important-stat {
  color: #d54941;
}

.stat-label {
  margin-top: 8rpx;
  color: #86909c;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.2;
  white-space: nowrap;
}

.stat-divider {
  width: 1rpx;
  height: 54rpx;
  background: #e5e8ef;
}

.important-section,
.search-box,
.notice-card,
.state-card {
  border-color: #e7ecf3;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.045);
}

.search-box {
  margin-top: 22rpx;
  height: 82rpx;
  border-radius: 18rpx;
}

.search-input {
  height: 82rpx;
  line-height: 82rpx;
}

.important-section {
  margin-top: 22rpx;
  margin-bottom: 22rpx;
  padding: 26rpx;
  border-radius: 22rpx;
}

.section-eyebrow {
  color: #0052d9;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.2;
}

.important-title {
  margin-top: 4rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
}

.section-count {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #667085;
  font-size: 23rpx;
  font-weight: 700;
}

.important-card,
.notice-card {
  border-radius: 20rpx;
}

.important-card {
  background: #f9fbff;
  border-color: #e8eef7;
}

.important-card::before,
.notice-card::before {
  width: 7rpx;
  background: #a1a9b8;
}

.important-card.category-exam::before,
.notice-card.category-exam::before {
  background: #d54941;
}

.important-card.category-homework::before,
.notice-card.category-homework::before {
  background: #0052d9;
}

.important-card.category-activity::before,
.notice-card.category-activity::before {
  background: #722ed1;
}

.important-card.category-notice::before,
.notice-card.category-notice::before {
  background: #00a870;
}

.important-card.category-other::before,
.notice-card.category-other::before {
  background: #86909c;
}

.important-card-title,
.card-title {
  color: #111827;
  font-weight: 800;
}

.important-time,
.time-row {
  border-radius: 14rpx;
  background: #f8fafc;
  border-color: #edf1f7;
}

.important-time {
  padding: 16rpx 18rpx;
}

.category {
  border-color: #e7ecf3;
  color: #4e5969;
  font-weight: 600;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.035);
}

.category.active {
  background: #0052d9;
  border-color: #0052d9;
  box-shadow: 0 8rpx 18rpx rgba(0, 82, 217, 0.18);
}

.status-filter {
  border-radius: 16rpx;
  background: #eef2f7;
  border-color: #e3e8ef;
}

.status-option {
  height: 54rpx;
  border-radius: 12rpx;
  color: #667085;
  font-weight: 700;
  line-height: 54rpx;
}

.status-option.active {
  color: #0052d9;
}

.tag,
.pin-tag,
.important,
.status-tag {
  font-weight: 700;
}

.category-exam .tag {
  background: #fff0ed;
  color: #c9352b;
}

.category-homework .tag {
  background: #edf3ff;
  color: #0052d9;
}

.category-activity .tag {
  background: #f4edff;
  color: #722ed1;
}

.category-notice .tag {
  background: #e8f8f1;
  color: #008858;
}

.pin-tag {
  background: #fff7e8;
  color: #b76e00;
}

.important {
  background: #fff0ed;
  color: #c9352b;
}

.notice-card.expired {
  opacity: 0.78;
}

.time-label,
.meta-label {
  color: #86909c;
}

.time-value {
  color: #1f2937;
  font-weight: 700;
}

.meta-value {
  color: #4e5969;
}

.state-card,
.verify-button,
.empty-mark {
  border-radius: 20rpx;
}

.verify-button {
  background: #0052d9;
  font-weight: 800;
  box-shadow: 0 8rpx 18rpx rgba(0, 82, 217, 0.18);
}

.empty-mark {
  background: #edf3ff;
  color: #0052d9;
}
