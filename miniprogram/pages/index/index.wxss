page {
  background: #f5f7fb;
}

.page {
  min-height: 100vh;
  padding: 24rpx 28rpx 52rpx;
}

.header {
  margin-bottom: 22rpx;
  padding: 28rpx 30rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e6edf5;
  box-shadow: 0 10rpx 24rpx rgba(30, 41, 59, 0.05);
}

.title {
  color: #0f172a;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.subtitle {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.45;
}

.search-box {
  height: 78rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e2eaf4;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 18rpx rgba(30, 41, 59, 0.04);
}

.search-icon {
  margin-right: 12rpx;
  color: #94a3b8;
  font-size: 30rpx;
  line-height: 1;
}

.search-input {
  flex: 1;
  height: 78rpx;
  color: #0f172a;
  font-size: 27rpx;
  line-height: 78rpx;
}

.search-placeholder {
  color: #94a3b8;
  font-size: 27rpx;
}

.important-section {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e6edf5;
  box-shadow: 0 10rpx 24rpx rgba(30, 41, 59, 0.045);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.important-title {
  color: #0f172a;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.3;
}

.section-count {
  flex: 0 0 auto;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.3;
}

.important-card {
  position: relative;
  margin-top: 18rpx;
  padding: 22rpx 22rpx 22rpx 26rpx;
  border-radius: 14rpx;
  background: #fbfdff;
  border: 1rpx solid #e7edf5;
  overflow: hidden;
  transition: transform 0.12s ease, box-shadow 0.12s ease, background-color 0.12s ease;
}

.important-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: #94a3b8;
}

.important-card.category-exam::before {
  background: #ef4444;
}

.important-card.category-homework::before {
  background: #2563eb;
}

.important-card.category-activity::before {
  background: #8b5cf6;
}

.important-card.category-notice::before {
  background: #10b981;
}

.important-card.category-other::before {
  background: #94a3b8;
}

.important-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.important-card-title {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.important-time {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.important-meta {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.important-meta-item {
  min-width: 0;
  width: calc((100% - 14rpx) / 2);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.filter-block {
  margin-top: 20rpx;
}

.filter-label {
  margin-bottom: 12rpx;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
}

.category-scroll {
  margin: 0 -28rpx;
  width: 750rpx;
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 12rpx;
  padding: 0 28rpx;
}

.category {
  flex: 0 0 auto;
  min-height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #e2eaf4;
  color: #475569;
  font-size: 26rpx;
  line-height: 58rpx;
  text-align: center;
  box-shadow: 0 5rpx 12rpx rgba(30, 41, 59, 0.035);
  transition: transform 0.12s ease, background-color 0.12s ease, border-color 0.12s ease;
}

.category.active {
  background: #2563eb;
  border-color: #2563eb;
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 7rpx 16rpx rgba(37, 99, 235, 0.16);
}

.status-block {
  margin-top: 16rpx;
}

.status-filter {
  margin: 0 0 22rpx;
  padding: 6rpx;
  border-radius: 12rpx;
  background: #eef3f8;
  border: 1rpx solid #e2eaf4;
  display: flex;
  gap: 6rpx;
}

.status-option {
  flex: 1;
  height: 50rpx;
  border-radius: 9rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 50rpx;
  text-align: center;
  transition: transform 0.12s ease, background-color 0.12s ease, color 0.12s ease;
}

.status-option.active {
  background: #ffffff;
  color: #2563eb;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(30, 41, 59, 0.06);
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-card {
  position: relative;
  overflow: hidden;
  padding: 24rpx 28rpx 26rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e6edf5;
  box-shadow: 0 10rpx 24rpx rgba(30, 41, 59, 0.05);
  transition: transform 0.12s ease, box-shadow 0.12s ease, background-color 0.12s ease;
}

.notice-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: #94a3b8;
}

.notice-card.category-exam::before {
  background: #ef4444;
}

.notice-card.category-homework::before {
  background: #2563eb;
}

.notice-card.category-activity::before {
  background: #8b5cf6;
}

.notice-card.category-notice::before {
  background: #10b981;
}

.notice-card.category-other::before {
  background: #94a3b8;
}

.notice-card.expired {
  background: #fbfcfe;
  border-color: #eef2f7;
  box-shadow: none;
  opacity: 0.86;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.tag-row {
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag,
.pin-tag,
.important,
.status-tag {
  min-height: 38rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tag {
  background: #f1f5f9;
  color: #334155;
}

.category-exam .tag {
  background: #fff1f2;
  color: #be123c;
}

.category-homework .tag {
  background: #eff6ff;
  color: #1d4ed8;
}

.category-activity .tag {
  background: #f5f3ff;
  color: #6d28d9;
}

.category-notice .tag {
  background: #ecfdf5;
  color: #047857;
}

.category-other .tag {
  background: #f1f5f9;
  color: #475569;
}

.pin-tag {
  background: #fff7ed;
  color: #c2410c;
  font-weight: 600;
}

.important {
  background: #fef2f2;
  color: #b91c1c;
  font-weight: 700;
}

.status-tag.active {
  background: #e7f8ef;
  color: #047857;
}

.status-tag.expired {
  background: #eef2f6;
  color: #64748b;
}

.card-title {
  margin-top: 16rpx;
  color: #0f172a;
  font-size: 33rpx;
  font-weight: 700;
  line-height: 1.36;
}

.notice-card.expired .card-title,
.notice-card.expired .time-value,
.notice-card.expired .meta-value {
  color: #64748b;
}

.time-row {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #e7edf5;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.time-label {
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
}

.time-value {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.info-grid {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.info-item {
  min-width: 0;
  width: calc((100% - 14rpx) / 2);
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.meta-label {
  color: #94a3b8;
  font-size: 23rpx;
}

.meta-value {
  color: #334155;
  font-size: 26rpx;
  line-height: 1.4;
  word-break: break-all;
}

.state-card {
  padding: 68rpx 30rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx dashed #cbd5e1;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(30, 41, 59, 0.035);
}

.state-card.error {
  border-color: #fecaca;
  background: #fff7f7;
}

.state-title {
  color: #475569;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
}

.state-desc {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 25rpx;
  line-height: 1.45;
}

.state-card.error .state-title {
  color: #b91c1c;
}

.verify-card {
  margin-top: 22rpx;
}

.verify-button {
  margin: 26rpx auto 0;
  width: 180rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.16);
}

.empty {
  padding-top: 58rpx;
  padding-bottom: 60rpx;
}

.empty-mark {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 20rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
}

.card-pressed {
  transform: scale(0.985);
  background: #f8fbff;
  box-shadow: 0 5rpx 14rpx rgba(30, 41, 59, 0.04);
}

.filter-pressed {
  transform: scale(0.97);
  opacity: 0.86;
}

.button-pressed {
  transform: scale(0.96);
  opacity: 0.9;
}
