/* 页面样式：定义 publish 页面的布局、视觉状态与响应式细节。 */
page {
  background: #f4f7fb;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 50rpx;
}

.button-hover {
  opacity: 0.84;
}

.publish-mode-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.publish-mode-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx 30rpx 32rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.06);
}

.publish-mode-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
}

.ai-mode-card {
  border-color: #b7ebd3;
}

.ai-mode-card::before {
  background: #10b981;
}

.manual-mode-card {
  border-color: #bfdbfe;
}

.manual-mode-card::before {
  background: #2563eb;
}

.mode-card-hover {
  opacity: 0.86;
  transform: scale(0.99);
}

.mode-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.mode-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.ai-mode-icon {
  background: #ecfdf5;
  color: #047857;
}

.manual-mode-icon {
  background: #eff6ff;
  color: #1d4ed8;
}

.mode-action {
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
}

.mode-title {
  margin-top: 24rpx;
  color: #0f172a;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
}

.mode-desc {
  margin-top: 12rpx;
  color: #334155;
  font-size: 28rpx;
  line-height: 1.5;
}

.mode-note {
  margin-top: 18rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.45;
}

.mode-back-button {
  margin: 0 0 22rpx;
  width: 100%;
  height: 68rpx;
  border-radius: 12rpx;
  background: #eef2f7;
  color: #475569;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 68rpx;
  text-align: center;
}

.form-section,
.state-card {
  padding: 30rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
}

.form-section {
  margin-top: 22rpx;
}

.section-title {
  color: #0f172a;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.3;
}

.section-desc {
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 24rpx;
  line-height: 1.45;
}

.field {
  margin-top: 28rpx;
}

.label {
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.label.required::after {
  content: " *";
  color: #e11d48;
}

.input,
.picker-value,
.textarea {
  width: 100%;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7f3;
  color: #111827;
  font-size: 28rpx;
}

.input,
.picker-value {
  height: 82rpx;
  padding: 0 22rpx;
  line-height: 82rpx;
}

.picker-value {
  display: flex;
  align-items: center;
}

.textarea {
  min-height: 190rpx;
  padding: 20rpx 22rpx;
  line-height: 1.6;
}

.helper {
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 22rpx;
  text-align: right;
}

.helper.left {
  text-align: left;
}

.time-label-picker {
  color: #1d4ed8;
}

.time-grid {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

.time-date-picker {
  flex: 1.25;
  min-width: 0;
}

.time-clock-picker {
  flex: 0.9;
  min-width: 0;
}

.time-clear-button {
  flex: 0 0 84rpx;
  margin: 0;
  width: 84rpx;
  height: 82rpx;
  border-radius: 12rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 24rpx;
  white-space: nowrap;
  visibility: hidden;
}

.time-clear-button.visible {
  visibility: visible;
}

.switch-field {
  margin-top: 28rpx;
  padding-top: 26rpx;
  border-top: 1rpx solid #eef2f7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.switch-tip {
  color: #94a3b8;
  font-size: 24rpx;
}

.image-toolbar {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.secondary-button {
  margin: 0;
  min-width: 176rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 26rpx;
  font-weight: 600;
}

.secondary-button[disabled] {
  background: #eef2f7;
  color: #94a3b8;
}

.image-count {
  color: #94a3b8;
  font-size: 24rpx;
}

.image-list {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.image-item {
  position: relative;
  overflow: hidden;
  width: calc((100% - 28rpx) / 3);
  height: 190rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7f3;
}

.preview-image {
  width: 100%;
  height: 100%;
  display: block;
}

.image-remove-button {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  margin: 0;
  width: 38rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.62);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.attachment-list,
.link-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.attachment-item,
.link-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7f3;
}

.attachment-info {
  flex: 1;
  min-width: 0;
}

.attachment-name {
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attachment-size {
  margin-top: 6rpx;
  color: #94a3b8;
  font-size: 23rpx;
}

.attachment-remove-button {
  flex: 0 0 84rpx;
  margin: 0;
  width: 84rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: #fef2f2;
  color: #b91c1c;
  font-size: 24rpx;
}

.link-inputs {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.link-input {
  background: #ffffff;
}

.link-remove-button {
  flex: 0 0 84rpx;
}

.submit-actions {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.reset-button {
  flex: 0 0 168rpx;
  margin: 0;
  height: 86rpx;
  border-radius: 14rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 86rpx;
  text-align: center;
}

.submit-button {
  flex: 1;
  margin: 0;
  height: 86rpx;
  border-radius: 14rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 86rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.18);
}

.submit-button[disabled] {
  background: #bfdbfe;
  color: #ffffff;
  box-shadow: none;
}

.state-card {
  color: #64748b;
  font-size: 28rpx;
  text-align: center;
}

.no-permission-title {
  color: #0f172a;
  font-size: 36rpx;
  font-weight: 700;
}

.no-permission-desc {
  margin-top: 16rpx;
  color: #334155;
  font-size: 28rpx;
}

.no-permission-tip {
  margin-top: 12rpx;
  color: #94a3b8;
  font-size: 26rpx;
}

.verify-button {
  margin: 28rpx auto 0;
  width: 180rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
}

.ai-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 34rpx 24rpx;
  box-sizing: border-box;
  background: rgba(15, 23, 42, 0.42);
}

.ai-panel {
  width: 100%;
  max-width: 680rpx;
  max-height: 84vh;
  border-radius: 18rpx;
  background: #ffffff;
  overflow: hidden;
  box-shadow: 0 22rpx 60rpx rgba(15, 23, 42, 0.18);
}

.ai-panel-header {
  padding: 30rpx 28rpx 22rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.ai-panel-title {
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 700;
}

.ai-scroll {
  max-height: calc(84vh - 220rpx);
  padding: 0 28rpx 18rpx;
  box-sizing: border-box;
}

.ai-input {
  min-height: 150rpx;
}

.ai-generate-button {
  margin: 22rpx 0 0;
  height: 78rpx;
  border-radius: 14rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 78rpx;
  box-shadow: 0 8rpx 18rpx rgba(15, 118, 110, 0.16);
}

.ai-generate-button[disabled] {
  background: #99f6e4;
  box-shadow: none;
}

.ai-draft {
  margin-top: 28rpx;
  padding-top: 6rpx;
  border-top: 1rpx solid #eef2f7;
}

.readonly-value {
  min-height: 82rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7f3;
  color: #475569;
  font-size: 28rpx;
  line-height: 82rpx;
}

.ai-warnings {
  margin-top: 28rpx;
  padding: 22rpx 24rpx;
  border-radius: 14rpx;
  background: #fff5f5;
  border: 1rpx solid #fecaca;
}

.ai-warnings-top {
  margin-top: 20rpx;
  margin-bottom: 4rpx;
}

.ai-warning-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ai-warning-mark {
  width: 8rpx;
  height: 30rpx;
  border-radius: 999rpx;
  background: #ef4444;
}

.ai-warning-title {
  color: #991b1b;
  font-size: 26rpx;
  font-weight: 700;
}

.ai-warning-list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.ai-warning-item {
  position: relative;
  padding-left: 22rpx;
  color: #7f1d1d;
  font-size: 25rpx;
  line-height: 1.55;
}

.ai-warning-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 15rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #ef4444;
}

.ai-actions {
  padding: 20rpx 28rpx calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-top: 1rpx solid #eef2f7;
  background: #ffffff;
}

.ai-cancel-button {
  flex: 0 0 168rpx;
  margin: 0;
  height: 80rpx;
  border-radius: 14rpx;
  background: #f1f5f9;
  color: #334155;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 80rpx;
  text-align: center;
}

.ai-cancel-button[disabled] {
  color: #94a3b8;
}

.ai-publish-button {
  flex: 1;
  margin: 0;
  height: 80rpx;
  border-radius: 14rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 80rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.18);
}

.ai-publish-button[disabled] {
  background: #bfdbfe;
  box-shadow: none;
}

/* TDesign-inspired visual refresh */
page {
  background: #f6f8fb;
}

.page {
  padding: 24rpx 28rpx 56rpx;
}

.publish-mode-list {
  gap: 20rpx;
}

.publish-mode-card {
  padding: 32rpx;
  border-radius: 24rpx;
  border-color: #e7ecf3;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.055);
}

.publish-mode-card::before {
  width: 8rpx;
}

.ai-mode-card {
  background: #fbfffd;
  border-color: #caeee0;
}

.manual-mode-card {
  background: #fbfdff;
  border-color: #d7e5ff;
}

.ai-mode-card::before {
  background: #00a870;
}

.manual-mode-card::before {
  background: #0052d9;
}

.mode-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
}

.ai-mode-icon {
  background: #e8f8f1;
  color: #008858;
}

.manual-mode-icon {
  background: #edf3ff;
  color: #0052d9;
}

.mode-action {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #667085;
  font-size: 23rpx;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04);
}

.mode-title {
  font-size: 38rpx;
  color: #111827;
}

.mode-desc {
  color: #1f2937;
}

.mode-note {
  color: #86909c;
}

.mode-back-button {
  height: 72rpx;
  border-radius: 16rpx;
  background: #eef2f7;
  color: #4e5969;
  font-weight: 700;
}

.form-section,
.state-card {
  border-radius: 22rpx;
  border-color: #e7ecf3;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.045);
}

.form-section {
  margin-top: 20rpx;
  padding: 28rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
}

.section-index {
  flex: 0 0 auto;
  min-width: 48rpx;
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #edf3ff;
  color: #0052d9;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 40rpx;
  text-align: center;
}

.section-desc,
.helper,
.switch-tip,
.image-count {
  color: #86909c;
}

.field {
  margin-top: 26rpx;
}

.label {
  color: #1f2937;
  font-weight: 700;
}

.label.required::after {
  color: #d54941;
}

.input,
.picker-value,
.textarea,
.readonly-value {
  border-radius: 16rpx;
  background: #f8fafc;
  border-color: #dce3ee;
  color: #111827;
}

.input,
.picker-value,
.readonly-value {
  height: 84rpx;
  line-height: 84rpx;
}

.textarea {
  min-height: 196rpx;
}

.time-label-picker {
  color: #0052d9;
  font-weight: 700;
}

.time-clear-button,
.secondary-button,
.reset-button {
  border-radius: 16rpx;
  background: #edf3ff;
  color: #0052d9;
  font-weight: 700;
}

.time-clear-button {
  height: 84rpx;
}

.secondary-button[disabled],
.submit-button[disabled],
.ai-generate-button[disabled],
.ai-publish-button[disabled] {
  background: #d7e5ff;
  color: #ffffff;
}

.switch-field {
  border-top-color: #edf1f7;
}

.image-item,
.attachment-item,
.link-item {
  border-radius: 16rpx;
  background: #f8fafc;
  border-color: #dce3ee;
}

.image-remove-button {
  background: rgba(17, 24, 39, 0.66);
}

.attachment-remove-button {
  border-radius: 14rpx;
  background: #fff0ed;
  color: #c9352b;
  font-weight: 700;
}

.submit-actions {
  margin-top: 30rpx;
}

.submit-button,
.verify-button,
.ai-publish-button {
  border-radius: 16rpx;
  background: #0052d9;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(0, 82, 217, 0.18);
}

.reset-button {
  height: 86rpx;
}

.no-permission-title {
  color: #111827;
  font-weight: 800;
}

.no-permission-desc {
  color: #4e5969;
}

.no-permission-tip {
  color: #86909c;
}

.ai-mask {
  background: rgba(15, 23, 42, 0.46);
}

.ai-panel {
  border-radius: 24rpx;
  box-shadow: 0 24rpx 70rpx rgba(15, 23, 42, 0.2);
}

.ai-panel-header,
.ai-actions {
  border-color: #edf1f7;
}

.ai-panel-title {
  color: #111827;
  font-weight: 800;
}

.ai-generate-button {
  border-radius: 16rpx;
  background: #00a870;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(0, 168, 112, 0.16);
}

.ai-cancel-button {
  border-radius: 16rpx;
  background: #f2f4f7;
  color: #4e5969;
}

.ai-warnings {
  border-radius: 18rpx;
  background: #fff7f5;
  border-color: #f4c7c3;
}

.ai-warning-mark,
.ai-warning-item::before {
  background: #d54941;
}
