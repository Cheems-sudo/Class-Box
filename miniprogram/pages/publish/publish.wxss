page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 50rpx;
}

.page-title {
  margin-bottom: 22rpx;
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.form-section,
.state-card {
  padding: 30rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
}

.form-section {
  margin-top: 22rpx;
}

.section-title {
  color: #0f172a;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.3;
}

.section-desc {
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 24rpx;
  line-height: 1.45;
}

.field {
  margin-top: 28rpx;
}

.label {
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.label.required::after {
  content: " *";
  color: #e11d48;
}

.input,
.picker-value,
.textarea {
  width: 100%;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7f3;
  color: #111827;
  font-size: 28rpx;
}

.input,
.picker-value {
  height: 82rpx;
  padding: 0 22rpx;
  line-height: 82rpx;
}

.picker-value {
  display: flex;
  align-items: center;
}

.textarea {
  min-height: 190rpx;
  padding: 20rpx 22rpx;
  line-height: 1.6;
}

.helper {
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 22rpx;
  text-align: right;
}

.helper.left {
  text-align: left;
}

.time-label-picker {
  color: #1d4ed8;
}

.time-grid {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

.time-date-picker {
  flex: 1.25;
  min-width: 0;
}

.time-clock-picker {
  flex: 0.9;
  min-width: 0;
}

.time-clear-button {
  flex: 0 0 84rpx;
  margin: 0;
  width: 84rpx;
  height: 82rpx;
  border-radius: 12rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 24rpx;
  white-space: nowrap;
  visibility: hidden;
}

.time-clear-button.visible {
  visibility: visible;
}

.switch-field {
  margin-top: 28rpx;
  padding-top: 26rpx;
  border-top: 1rpx solid #eef2f7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.switch-tip {
  color: #94a3b8;
  font-size: 24rpx;
}

.image-toolbar {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.secondary-button {
  margin: 0;
  min-width: 176rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 26rpx;
  font-weight: 600;
}

.secondary-button[disabled] {
  background: #eef2f7;
  color: #94a3b8;
}

.image-count {
  color: #94a3b8;
  font-size: 24rpx;
}

.image-list {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.image-item {
  position: relative;
  overflow: hidden;
  width: calc((100% - 28rpx) / 3);
  height: 190rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7f3;
}

.preview-image {
  width: 100%;
  height: 100%;
  display: block;
}

.image-remove-button {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  margin: 0;
  width: 38rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.62);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.attachment-list,
.link-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.attachment-item,
.link-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7f3;
}

.attachment-info {
  flex: 1;
  min-width: 0;
}

.attachment-name {
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attachment-size {
  margin-top: 6rpx;
  color: #94a3b8;
  font-size: 23rpx;
}

.attachment-remove-button {
  flex: 0 0 84rpx;
  margin: 0;
  width: 84rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: #fef2f2;
  color: #b91c1c;
  font-size: 24rpx;
}

.link-inputs {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.link-input {
  background: #ffffff;
}

.link-remove-button {
  flex: 0 0 84rpx;
}

.submit-actions {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.reset-button {
  flex: 0 0 168rpx;
  margin: 0;
  height: 86rpx;
  border-radius: 14rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 86rpx;
  text-align: center;
}

.submit-button {
  flex: 1;
  margin: 0;
  height: 86rpx;
  border-radius: 14rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 86rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.18);
}

.state-card {
  color: #64748b;
  font-size: 28rpx;
  text-align: center;
}

.no-permission-title {
  color: #0f172a;
  font-size: 36rpx;
  font-weight: 700;
}

.no-permission-desc {
  margin-top: 16rpx;
  color: #334155;
  font-size: 28rpx;
}

.no-permission-tip {
  margin-top: 12rpx;
  color: #94a3b8;
  font-size: 26rpx;
}

.verify-button {
  margin: 28rpx auto 0;
  width: 180rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
}
