<page-meta page-style="{{aiModalVisible ? 'overflow: hidden;' : ''}}"></page-meta>

<view class="page">
  <view wx:if="{{authLoading}}" class="state-card">权限加载中...</view>

  <view wx:elif="{{!verified}}" class="state-card no-permission-card">
    <view class="no-permission-title">请先完成班级身份验证</view>
    <view class="no-permission-desc">验证后即可使用班级盒子主要功能</view>
    <button class="verify-button" bindtap="goMemberVerify">去验证</button>
  </view>

  <view wx:elif="{{canPublish}}">
    <view class="page-title">{{isEdit ? '编辑事项' : '发布班务事项'}}</view>

    <view wx:if="{{!isEdit && publishMode != 'manual'}}" class="publish-mode-list">
      <view class="publish-mode-card ai-mode-card" bindtap="selectAiPublishMode" hover-class="mode-card-hover">
        <view class="mode-card-top">
          <view class="mode-icon ai-mode-icon">AI</view>
          <view class="mode-action">快速开始</view>
        </view>
        <view class="mode-title">AI 快速发布</view>
        <view class="mode-desc">输入一句话，自动整理标题、时间、地点和内容</view>
        <view class="mode-note">适合考试、作业、班会、活动通知</view>
      </view>

      <view class="publish-mode-card manual-mode-card" bindtap="selectManualPublishMode" hover-class="mode-card-hover">
        <view class="mode-card-top">
          <view class="mode-icon manual-mode-icon">填</view>
          <view class="mode-action">完整填写</view>
        </view>
        <view class="mode-title">手动发布</view>
        <view class="mode-desc">逐项填写完整信息</view>
        <view class="mode-note">适合带图片、附件、链接的复杂事项</view>
      </view>
    </view>

    <block wx:if="{{isEdit || publishMode === 'manual'}}">
    <button wx:if="{{!isEdit}}" class="mode-back-button" bindtap="resetPublishMode" hover-class="button-hover">重新选择发布方式</button>

    <view class="form-section">
      <view class="section-title">基础信息</view>

      <view class="field">
        <view class="label required">标题</view>
        <input
          class="input"
          value="{{form.title}}"
          maxlength="30"
          placeholder="例如：高等数学期中考试"
          bindinput="onTitleInput"
        />
        <view class="helper">{{form.title.length}}/30</view>
      </view>

      <view class="field">
        <view class="label required">分类选择</view>
        <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="changeCategory">
          <view class="picker-value">{{form.category || '请选择分类'}}</view>
        </picker>
      </view>

      <view class="field">
        <view class="label">{{courseLabel}}</view>
        <input
          class="input"
          value="{{form.course}}"
          placeholder="{{coursePlaceholder}}"
          bindinput="onCourseInput"
        />
      </view>

      <view class="field">
        <view class="label">{{locationLabel}}</view>
        <input
          class="input"
          value="{{form.location}}"
          placeholder="{{locationPlaceholder}}"
          bindinput="onLocationInput"
        />
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">时间信息</view>

      <view class="field" wx:if="{{timeConfig.showTimeLabelPicker}}">
        <view class="label required">时间类型</view>
        <picker mode="selector" range="{{timeLabelOptions}}" value="{{timeLabelIndex}}" bindchange="changeTimeLabel">
          <view class="picker-value time-label-picker">{{form.timeLabel || '选择时间类型'}}</view>
        </picker>
      </view>

      <view class="field">
        <view class="label required">{{timeConfig.mainLabel}}</view>
        <view class="time-grid">
          <picker class="time-date-picker" mode="date" value="{{form.date}}" bindchange="onDateChange">
            <view class="picker-value">{{form.date || '选择日期'}}</view>
          </picker>
          <picker class="time-clock-picker" mode="time" value="{{form.time}}" bindchange="onTimeChange">
            <view class="picker-value">{{form.time || '选时间'}}</view>
          </picker>
          <button class="time-clear-button {{form.time ? 'visible' : ''}}" disabled="{{!form.time}}" bindtap="clearMainTime">清空</button>
        </view>
      </view>

      <view class="field" wx:if="{{timeConfig.showEndTime}}">
        <view class="label">{{timeConfig.endSectionLabel}}</view>
        <view class="time-grid">
          <picker class="time-date-picker" mode="date" value="{{form.endDate}}" bindchange="onEndDateChange">
            <view class="picker-value">{{form.endDate || '选日期'}}</view>
          </picker>
          <picker class="time-clock-picker" mode="time" value="{{form.endClock}}" bindchange="onEndTimeChange">
            <view class="picker-value">{{form.endClock || '选时间'}}</view>
          </picker>
          <button class="time-clear-button {{(form.endDate || form.endClock) ? 'visible' : ''}}" disabled="{{!(form.endDate || form.endClock)}}" bindtap="clearEndTime">清空</button>
        </view>
        <view class="helper left">结束时间可不填；填写后需晚于开始时间</view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">详细内容</view>

      <view class="field">
        <view class="label required">详细内容</view>
        <textarea
          class="textarea"
          value="{{form.content}}"
          maxlength="500"
          placeholder="补充说明事项要求、材料、注意事项等"
          bindinput="onContentInput"
        ></textarea>
        <view class="helper">{{form.content.length}}/500</view>
      </view>

      <view class="switch-field">
        <view>
          <view class="label">是否重要</view>
          <view class="switch-tip">重要事项会在卡片上显示标记</view>
        </view>
        <switch checked="{{form.isImportant}}" color="#1e80ff" bindchange="onImportantChange" />
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">相关图片</view>
      <view class="section-desc">最多上传6张图片</view>

      <view class="image-toolbar">
        <button class="secondary-button" bindtap="chooseImages" disabled="{{existingImages.length + newImages.length >= maxImageCount}}">选择图片</button>
        <view class="image-count">{{existingImages.length + newImages.length}}/{{maxImageCount}}</view>
      </view>
      <view class="image-list" wx:if="{{existingImages.length || newImages.length}}">
        <view class="image-item" wx:for="{{existingImages}}" wx:key="fileID" data-url="{{item.tempFileURL || item.fileID || item.url}}" bindtap="previewSelectedImage">
          <image class="preview-image" src="{{item.tempFileURL || item.fileID || item.url}}" mode="aspectFill"></image>
          <button class="image-remove-button" data-index="{{index}}" catchtap="removeExistingImage">×</button>
        </view>
        <view class="image-item" wx:for="{{newImages}}" wx:key="tempFilePath" data-url="{{item.tempFilePath}}" bindtap="previewSelectedImage">
          <image class="preview-image" src="{{item.tempFilePath}}" mode="aspectFill"></image>
          <button class="image-remove-button" data-index="{{index}}" catchtap="removeNewImage">×</button>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">相关附件</view>
      <view class="section-desc">附件将从微信聊天文件中选择，首次加载可能较慢；较大附件建议使用电脑端上传，体验更稳定</view>

      <view class="image-toolbar">
        <button class="secondary-button" bindtap="chooseAttachments" disabled="{{existingAttachments.length + newAttachments.length >= maxAttachmentCount}}">选择附件</button>
        <view class="image-count">{{existingAttachments.length + newAttachments.length}}/{{maxAttachmentCount}}</view>
      </view>
      <view class="attachment-list" wx:if="{{existingAttachments.length || newAttachments.length}}">
        <view class="attachment-item" wx:for="{{existingAttachments}}" wx:key="fileID">
          <view class="attachment-info">
            <view class="attachment-name">{{item.name}}</view>
            <view class="attachment-size">{{item.formattedSize}}</view>
          </view>
          <button class="attachment-remove-button" data-index="{{index}}" bindtap="removeExistingAttachment">删除</button>
        </view>
        <view class="attachment-item" wx:for="{{newAttachments}}" wx:key="tempFilePath">
          <view class="attachment-info">
            <view class="attachment-name">{{item.name}}</view>
            <view class="attachment-size">{{item.formattedSize}}</view>
          </view>
          <button class="attachment-remove-button" data-index="{{index}}" bindtap="removeNewAttachment">删除</button>
        </view>
      </view>
      <view class="helper left">支持 PDF、Word、Excel、PPT，单个文件不超过20MB</view>
    </view>

    <view class="form-section">
      <view class="section-title">相关链接</view>

      <view class="image-toolbar">
        <button class="secondary-button" bindtap="addLink" disabled="{{form.links.length >= maxLinkCount}}">添加链接</button>
        <view class="image-count">{{form.links.length}}/{{maxLinkCount}}</view>
      </view>
      <view class="link-list" wx:if="{{form.links.length}}">
        <view class="link-item" wx:for="{{form.links}}" wx:key="index">
          <view class="link-inputs">
            <input
              class="input link-input"
              value="{{item.title}}"
              placeholder="链接标题"
              data-index="{{index}}"
              bindinput="onLinkTitleInput"
            />
            <input
              class="input link-input"
              value="{{item.url}}"
              placeholder="https://example.com"
              data-index="{{index}}"
              bindinput="onLinkUrlInput"
            />
          </view>
          <button class="attachment-remove-button link-remove-button" data-index="{{index}}" bindtap="removeLink">删除</button>
        </view>
      </view>
      <view class="helper left">最多添加3个链接，支持 http:// 和 https://</view>
    </view>

    <view class="submit-actions">
      <button wx:if="{{!isEdit}}" class="reset-button" bindtap="handleResetForm">重置</button>
      <button class="submit-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitForm">{{isEdit ? '保存修改' : '发布'}}</button>
    </view>
    </block>

    <view wx:if="{{aiModalVisible}}" class="ai-mask" catchtouchmove="noop">
      <view class="ai-panel" catchtap="noop">
        <view class="ai-panel-header">
          <view class="ai-panel-title">AI 辅助发布</view>
        </view>

        <scroll-view class="ai-scroll" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}">
          <view class="field">
            <view class="label required">一句话描述</view>
            <textarea
              class="textarea ai-input"
              maxlength="500"
              adjust-position="{{false}}"
              cursor-spacing="24"
              placeholder="例如：明天下午三点到五点在C3-104考高数，记得带学生证"
              bindinput="onAiInput"
              bindblur="onAiInputBlur"
            ></textarea>
          </view>

          <button class="ai-generate-button" loading="{{aiGenerating}}" disabled="{{aiGenerating || aiPublishing}}" bindtap="generateAiDraft" hover-class="button-hover">
            {{aiGenerating ? '生成中' : '生成草稿'}}
          </button>

          <view wx:if="{{aiDraftReady}}" class="ai-draft">
            <view wx:if="{{aiDraft.warnings.length}}" class="ai-warnings ai-warnings-top">
              <view class="ai-warning-header">
                <view class="ai-warning-mark"></view>
                <view class="ai-warning-title">需要确认的信息</view>
              </view>
              <view class="ai-warning-list">
                <view class="ai-warning-item" wx:for="{{aiDraft.warnings}}" wx:key="index">{{item}}</view>
              </view>
            </view>

            <view class="field">
              <view class="label required">标题</view>
              <input class="input" value="{{aiDraft.title}}" maxlength="30" data-field="title" bindinput="onAiDraftFieldInput" />
              <view class="helper">{{aiDraft.title.length}}/30</view>
            </view>

            <view class="field">
              <view class="label required">分类选择</view>
              <picker mode="selector" range="{{categories}}" value="{{aiCategoryIndex}}" bindchange="changeAiCategory">
                <view class="picker-value">{{aiDraft.category || '请选择分类'}}</view>
              </picker>
            </view>

            <view class="field">
              <view class="label required">时间类型</view>
              <picker mode="selector" range="{{aiTimeLabelOptions}}" value="{{aiTimeLabelIndex}}" bindchange="changeAiTimeLabel">
                <view class="picker-value time-label-picker">{{aiDraft.timeLabel || '选择时间类型'}}</view>
              </picker>
            </view>

            <view class="field">
              <view class="label">课程 / 事项名称</view>
              <input class="input" value="{{aiDraft.course}}" data-field="course" bindinput="onAiDraftFieldInput" />
            </view>

            <view class="field">
              <view class="label required">开始 / 截止 / 相关时间</view>
              <view class="time-grid">
                <picker class="time-date-picker" mode="date" value="{{aiDeadlineDate}}" bindchange="onAiDeadlineDateChange">
                  <view class="picker-value">{{aiDeadlineDate || '选择日期'}}</view>
                </picker>
                <picker class="time-clock-picker" mode="time" value="{{aiDeadlineTime}}" bindchange="onAiDeadlineTimeChange">
                  <view class="picker-value">{{aiDeadlineTime || '选时间'}}</view>
                </picker>
                <button class="time-clear-button {{aiDeadlineTime ? 'visible' : ''}}" disabled="{{!aiDeadlineTime}}" bindtap="clearAiDeadlineTime">清空</button>
              </view>
            </view>

            <view class="field">
              <view class="label">结束时间</view>
              <view class="time-grid">
                <picker class="time-date-picker" mode="date" value="{{aiEndDate}}" bindchange="onAiEndDateChange">
                  <view class="picker-value">{{aiEndDate || '选日期'}}</view>
                </picker>
                <picker class="time-clock-picker" mode="time" value="{{aiEndTime}}" bindchange="onAiEndTimeChange">
                  <view class="picker-value">{{aiEndTime || '选时间'}}</view>
                </picker>
                <button class="time-clear-button {{(aiEndDate || aiEndTime) ? 'visible' : ''}}" disabled="{{!(aiEndDate || aiEndTime)}}" bindtap="clearAiEndTime">清空</button>
              </view>
              <view class="helper left">结束时间可不填；填写后需晚于开始时间</view>
            </view>

            <view class="field">
              <view class="label">地点</view>
              <input class="input" value="{{aiDraft.location}}" data-field="location" bindinput="onAiDraftFieldInput" />
            </view>

            <view class="field">
              <view class="label required">详细内容</view>
              <textarea class="textarea" value="{{aiDraft.content}}" maxlength="500" adjust-position="{{false}}" cursor-spacing="24" data-field="content" bindinput="onAiDraftFieldInput"></textarea>
              <view class="helper">{{aiDraft.content.length}}/500</view>
            </view>

            <view class="switch-field">
              <view>
                <view class="label">是否重要</view>
                <view class="switch-tip">重要事项会在卡片上显示标记</view>
              </view>
              <switch checked="{{aiDraft.isImportant}}" color="#1e80ff" bindchange="onAiImportantChange" />
            </view>

            <view class="field">
              <view class="label">发布人</view>
              <view class="readonly-value">{{publisherName}}</view>
            </view>
          </view>
        </scroll-view>

        <view class="ai-actions">
          <button class="ai-cancel-button" bindtap="closeAiModal" disabled="{{aiGenerating || aiPublishing}}" hover-class="button-hover">取消</button>
          <button class="ai-publish-button" loading="{{aiPublishing}}" disabled="{{!aiDraftReady || aiGenerating || aiPublishing}}" bindtap="submitAiDraft" hover-class="button-hover">
            {{aiPublishing ? '发布中' : '发布'}}
          </button>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="state-card no-permission-card">
    <view class="no-permission-title">暂无发布权限</view>
    <view class="no-permission-desc">只有班委可以发布班级事项</view>
    <view class="no-permission-tip">如需开通权限，请联系班长</view>
  </view>
</view>
