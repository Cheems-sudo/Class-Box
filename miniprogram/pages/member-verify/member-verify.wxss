/* 页面样式：定义 member-verify 页面的布局、视觉状态与响应式细节。 */
page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.verify-card {
  padding: 34rpx 30rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
}

.title {
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
}

.desc {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.5;
}

.field {
  margin-top: 30rpx;
}

.label {
  margin-bottom: 12rpx;
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 600;
}

.input {
  width: 100%;
  height: 82rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7f3;
  color: #111827;
  font-size: 28rpx;
  line-height: 82rpx;
}

.placeholder {
  color: #94a3b8;
}

.error-message {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #fff5f5;
  border: 1rpx solid #fecaca;
  color: #991b1b;
  font-size: 25rpx;
  line-height: 1.45;
}

.submit-button {
  margin-top: 36rpx;
  height: 86rpx;
  border-radius: 14rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.18);
}

.submit-button[disabled] {
  background: #93c5fd;
  color: #ffffff;
}
