<view class="page">
  <view class="profile-card">
    <view class="profile-main" wx:if="{{verified}}">
      <view class="profile-name">{{name}}</view>
      <view class="profile-student-id">学号：{{studentId}}</view>
    </view>

    <view class="profile-main" wx:else>
      <view class="profile-name muted">未完成身份验证</view>
      <view class="profile-student-id">完成验证后显示姓名和学号</view>
    </view>

    <view class="badge-row">
      <view class="badge {{verified ? 'success' : 'warning'}}">班级身份：{{verified ? '已验证' : '未验证'}}</view>
      <view class="badge {{isAdmin ? 'admin' : ''}}">系统身份：{{roleText}}</view>
    </view>

    <button class="verify-button" wx:if="{{!verified}}" bindtap="goMemberVerify">去验证</button>
  </view>

  <view class="feature-section" wx:if="{{verified}}">
    <view class="section-title">常用功能</view>
    <view class="feature-grid">
      <view class="feature-item" bindtap="goFavorites">
        <view class="feature-title">我的收藏</view>
        <view class="feature-desc">查看已收藏事项</view>
      </view>

      <view class="feature-item" wx:if="{{!subscribeLoading}}" bindtap="subscribeNextNotice">
        <view class="feature-title">消息提醒</view>
        <view class="feature-desc">接收下一条通知</view>
      </view>

      <view class="feature-item disabled" wx:else catchtap="noop">
        <view class="feature-title">订阅中</view>
        <view class="feature-desc">接收下一条通知</view>
      </view>

      <view class="feature-item" wx:if="{{role === 'admin' || role === 'superAdmin'}}" bindtap="goMyPosts">
        <view class="feature-title">我发布的事项</view>
        <view class="feature-desc">管理发布内容</view>
      </view>

      <view class="feature-item" wx:if="{{role === 'user'}}" bindtap="goAdminAuth">
        <view class="feature-title">开通管理员权限</view>
        <view class="feature-desc">使用邀请码开通</view>
      </view>
    </view>
    <view class="feature-note">订阅消息为一次性授权，发送后需重新订阅。</view>
  </view>
</view>
