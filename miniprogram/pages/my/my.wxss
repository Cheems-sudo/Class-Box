page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.profile-card,
.admin-status-card,
.notice-subscribe-card,
.favorite-card,
.my-posts-card,
.admin-apply-card {
  padding: 30rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
}

.profile-card {
  padding: 34rpx 30rpx 30rpx;
}

.admin-status-card,
.notice-subscribe-card,
.favorite-card,
.my-posts-card,
.admin-apply-card {
  margin-top: 22rpx;
}

.profile-main {
  min-height: 86rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.profile-name {
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
}

.profile-name.muted {
  color: #334155;
  font-size: 34rpx;
}

.profile-student-id {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.35;
}

.badge-row {
  margin-top: 26rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef2f6;
  color: #475569;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
}

.badge.success {
  background: #e7f8ef;
  color: #047857;
}

.badge.warning {
  background: #fff7ed;
  color: #b45309;
}

.badge.admin {
  background: #eff6ff;
  color: #1d4ed8;
}

.verify-button,
.subscribe-button {
  border-radius: 12rpx;
  background: #2563eb;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.16);
}

.verify-button {
  margin: 28rpx 0 0;
  width: 208rpx;
  height: 76rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.admin-status-card {
  padding: 24rpx 28rpx;
  box-shadow: none;
}

.admin-status-title {
  color: #047857;
  font-size: 26rpx;
  font-weight: 600;
}

.super-admin .admin-status-title {
  color: #1d4ed8;
}

.card-title {
  color: #0f172a;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.3;
}

.card-subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.45;
}

.subscribe-button {
  margin-top: 24rpx;
  height: 76rpx;
  font-size: 28rpx;
}

.admin-apply-entry,
.my-posts-entry,
.favorite-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 78rpx;
}

.entry-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  min-width: 92rpx;
  min-height: 48rpx;
  color: #2563eb;
  font-size: 25rpx;
  font-weight: 600;
}

.entry-arrow {
  margin-left: 8rpx;
  font-size: 38rpx;
  line-height: 1;
}
