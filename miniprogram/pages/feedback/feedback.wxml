<!-- 页面结构：组织 feedback 页面的内容区域与交互控件。 -->
<view class="page">
  <view class="header">
    <view class="title">意见反馈</view>
    <view class="subtitle">欢迎提交你遇到的问题和建议</view>
  </view>

  <view class="feedback-card">
    <view class="field-label">反馈内容</view>
    <textarea
      class="feedback-input"
      value="{{content}}"
      maxlength="{{maxLength}}"
      placeholder="请描述问题或建议"
      placeholder-class="input-placeholder"
      bindinput="onContentInput"
      disabled="{{submitting}}"
      auto-height="{{false}}"
      show-confirm-bar="{{false}}"
    />
    <view class="input-meta">
      <view class="hint">至少 2 个字</view>
      <view class="count {{contentLength > maxLength ? 'error' : ''}}">{{contentLength}}/{{maxLength}}</view>
    </view>
  </view>

  <button
    class="submit-button"
    type="primary"
    disabled="{{submitting}}"
    bindtap="submitFeedback"
  >
    {{submitting ? "提交中" : "提交反馈"}}
  </button>
</view>
