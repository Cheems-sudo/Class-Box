/* 页面样式：定义 feedback 页面的布局、视觉状态与响应式细节。 */
page {
  background: #f6f8fb;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.header {
  padding: 18rpx 4rpx 24rpx;
}

.title {
  color: #111827;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.25;
}

.subtitle {
  margin-top: 10rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.45;
}

.feedback-card {
  padding: 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e7ecf3;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.055);
}

.field-label {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.feedback-input {
  margin-top: 20rpx;
  width: 100%;
  height: 320rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e3e8ef;
  color: #111827;
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
}

.input-placeholder {
  color: #9aa4b2;
}

.input-meta {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  color: #86909c;
  font-size: 24rpx;
  line-height: 1.4;
}

.hint,
.count {
  min-width: 0;
}

.count.error {
  color: #d92d20;
}

.submit-button {
  margin-top: 28rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #0052d9;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
  box-shadow: 0 12rpx 24rpx rgba(0, 82, 217, 0.18);
}

.submit-button[disabled] {
  background: #a8c5f5;
  color: rgba(255, 255, 255, 0.9);
}
