page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.auth-card {
  padding: 34rpx 30rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
}

.page-title {
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
}

.page-desc {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.5;
}

.field {
  margin-top: 30rpx;
}

.field-label {
  margin-bottom: 12rpx;
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 82rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7f3;
  color: #111827;
  font-size: 28rpx;
  line-height: 82rpx;
}

.input-placeholder {
  color: #94a3b8;
  font-size: 27rpx;
}

.submit-button,
.secondary-button {
  margin-top: 36rpx;
  height: 86rpx;
  border-radius: 14rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.18);
}

.secondary-button {
  background: #eff6ff;
  color: #1d4ed8;
  box-shadow: none;
}

.submit-button[disabled] {
  background: #93c5fd;
  color: #ffffff;
}
