<view class="page">
  <view class="header">
    <view class="title">我发布的事项</view>
    <view class="subtitle">查看和管理自己发布的内容</view>
  </view>

  <view class="state-card" wx:if="{{authLoading}}">
    <view class="state-title">身份检查中...</view>
    <view class="state-desc">正在确认管理权限</view>
  </view>

  <view class="state-card" wx:elif="{{!verified}}">
    <view class="state-title">请先完成班级身份验证</view>
  </view>

  <view class="state-card" wx:elif="{{!canView}}">
    <view class="state-title">暂无管理权限</view>
  </view>

  <view class="card-list" wx:else>
    <view class="state-card" wx:if="{{isLoading}}">
      <view class="state-title">加载中...</view>
      <view class="state-desc">正在同步你发布的事项</view>
    </view>

    <view class="state-card error" wx:elif="{{loadError}}">
      <view class="state-title">加载失败，请下拉刷新重试</view>
      <view class="state-desc">请检查网络或稍后再试</view>
    </view>

    <block wx:else>
      <view
        class="notice-card {{item.isExpired ? 'expired' : ''}}"
        wx:for="{{noticeList}}"
        wx:key="_id"
        data-id="{{item._id}}"
        bindtap="goDetail"
      >
        <view class="card-top">
          <view class="tag-row">
            <view class="tag">{{item.category}}</view>
            <view class="status-tag {{item.isExpired ? 'expired' : 'active'}}">{{item.statusText}}</view>
          </view>
        </view>
        <view class="card-title">{{item.title}}</view>
        <view class="time-row">
          <text class="time-label">{{item.timeLabel || '时间'}}</text>
          <text class="time-value">{{item.timeText || item.deadline || '未填写'}}</text>
        </view>
        <view class="info-grid">
          <view class="info-item" wx:if="{{item.publisherNameText}}">
            <text class="meta-label">发布人</text>
            <text class="meta-value">{{item.publisherNameText}}</text>
          </view>
          <view class="info-item" wx:if="{{item.updatedAtText}}">
            <text class="meta-label">更新时间</text>
            <text class="meta-value">{{item.updatedAtText}}</text>
          </view>
        </view>
      </view>

      <view class="state-card empty" wx:if="{{noticeList.length == 0}}">
        <view class="state-title">暂无已发布事项</view>
      </view>
    </block>
  </view>
</view>
