page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.header {
  margin-bottom: 22rpx;
}

.title {
  color: #0f172a;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.45;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.notice-card {
  padding: 26rpx 28rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e5edf6;
  border-left: 6rpx solid #dbeafe;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.045);
}

.notice-card.expired {
  background: #fbfcfe;
  border-color: #eef2f7;
  box-shadow: none;
  opacity: 0.78;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.tag-row {
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag,
.status-tag {
  min-height: 38rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tag {
  background: #eff6ff;
  color: #1d4ed8;
}

.status-tag.active {
  background: #e7f8ef;
  color: #047857;
}

.status-tag.expired {
  background: #eef2f6;
  color: #64748b;
}

.card-title {
  margin-top: 18rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.notice-card.expired .card-title,
.notice-card.expired .time-value,
.notice-card.expired .meta-value {
  color: #64748b;
}

.time-row {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  border: 1rpx solid #e8eef6;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.time-label {
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
}

.time-value {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.info-grid {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.info-item {
  min-width: 0;
  width: calc((100% - 16rpx) / 2);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.meta-label {
  color: #94a3b8;
  font-size: 24rpx;
}

.meta-value {
  color: #334155;
  font-size: 27rpx;
  line-height: 1.4;
  word-break: break-all;
}

.state-card {
  padding: 72rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx dashed #cbd5e1;
  text-align: center;
}

.state-card.error {
  border-color: #fecaca;
  background: #fff7f7;
}

.state-title {
  color: #475569;
  font-size: 30rpx;
  font-weight: 600;
}

.state-desc {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 25rpx;
}

.state-card.error .state-title {
  color: #b91c1c;
}
