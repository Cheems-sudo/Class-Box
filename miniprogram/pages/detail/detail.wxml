<view class="page">
  <view class="content-card verify-card" wx:if="{{authLoading}}">
    <view class="section-title">身份检查中...</view>
  </view>

  <view class="content-card verify-card" wx:elif="{{!verified}}">
    <view class="section-title">请先完成班级身份验证</view>
    <view class="verify-desc">验证后即可查看事项详情</view>
    <button class="verify-button" bindtap="goMemberVerify">去验证</button>
  </view>

  <view class="content-card" wx:elif="{{notFound}}">
    <view class="section-title">事项不存在</view>
  </view>

  <view class="detail-card" wx:if="{{verified && detail && !notFound}}">
    <view class="tag-row">
      <view class="tag">{{detail.category}}</view>
      <view class="pin-tag" wx:if="{{detail.isPinned}}">置顶</view>
      <view class="important-tag" wx:if="{{detail.important || detail.isImportant}}">重要</view>
      <view class="status-tag {{detail.isExpired ? 'expired' : 'active'}}">{{detail.statusText}}</view>
    </view>
    <view class="title">{{detail.title}}</view>
    <view class="time-panel">
      <view class="info-row primary">
        <text class="label">{{detail.timeLabel || '时间'}}</text>
        <text class="value">{{detail.timeText || detail.deadline}}</text>
      </view>
    </view>
    <view class="info-list">
      <view class="info-row" wx:if="{{detail.courseText}}">
        <text class="label">{{detail.courseLabel}}</text>
        <text class="value">{{detail.courseText}}</text>
      </view>
      <view class="info-row" wx:if="{{detail.locationText}}">
        <text class="label">{{detail.locationLabel}}</text>
        <text class="value">{{detail.locationText}}</text>
      </view>
      <view class="info-row">
        <text class="label">发布人</text>
        <text class="value">{{detail.publisherNameText || '未知'}}</text>
      </view>
    </view>
    <button
      class="favorite-button {{isFavorited ? 'active' : ''}}"
      loading="{{favoriteLoading}}"
      disabled="{{favoriteLoading}}"
      bindtap="toggleFavorite"
    >
      {{isFavorited ? '取消收藏' : '收藏'}}
    </button>
  </view>

  <view class="content-card" wx:if="{{verified && detail && !notFound}}">
    <view class="section-title-row">
      <view class="section-title">详细内容</view>
    </view>
    <view class="content">{{detail.content}}</view>
  </view>

  <view class="content-card" wx:if="{{verified && detail && !notFound && detail.images.length}}">
    <view class="section-title-row">
      <view class="section-title">相关图片</view>
      <view class="section-count">{{detail.images.length}}</view>
    </view>
    <view class="image-grid">
      <view
        class="image-card"
        wx:for="{{detail.images}}"
        wx:key="fileID"
        data-index="{{index}}"
        bindtap="previewImage"
      >
        <image class="detail-image" src="{{item.tempFileURL || item.fileID || item.url}}" mode="aspectFill"></image>
      </view>
    </view>
  </view>

  <view class="content-card" wx:if="{{verified && detail && !notFound && detail.attachments.length}}">
    <view class="section-title-row">
      <view class="section-title">相关附件</view>
      <view class="section-count">{{detail.attachments.length}}</view>
    </view>
    <view class="attachment-list">
      <view class="attachment-card" wx:for="{{detail.attachments}}" wx:key="fileID">
        <view class="attachment-info">
          <view class="attachment-name">{{item.name}}</view>
          <view class="attachment-size">{{item.formattedSize}}</view>
        </view>
        <view class="attachment-open-button" data-index="{{index}}" bindtap="openAttachment">打开</view>
      </view>
    </view>
  </view>

  <view class="content-card" wx:if="{{verified && detail && !notFound && detail.links.length}}">
    <view class="section-title-row">
      <view class="section-title">相关链接</view>
      <view class="section-count">{{detail.links.length}}</view>
    </view>
    <view class="link-list">
      <view class="link-card" wx:for="{{detail.links}}" wx:key="url">
        <view class="link-info">
          <view class="link-title">{{item.title}}</view>
          <view class="link-url">{{item.url}}</view>
        </view>
        <button class="link-copy-button" data-index="{{index}}" bindtap="copyLink">复制链接</button>
      </view>
    </view>
  </view>

  <view class="admin-actions" wx:if="{{verified && detail && !notFound && canManage}}">
    <view class="section-title action-title">管理操作</view>
    <button class="pin-button" bindtap="togglePinNotice">{{detail.isPinned ? '取消置顶' : '置顶'}}</button>
    <button class="edit-button" bindtap="editNotice">编辑</button>
    <button class="delete-button" bindtap="deleteNotice">删除</button>
  </view>
</view>
